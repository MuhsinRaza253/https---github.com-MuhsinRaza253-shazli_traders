MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
JWT_SECRET=<generate-with-crypto-randomBytes-64-hex>
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
FRONTEND_URL=http://localhost:3000
PORT=5000

# Order notification emails (optional — orders still work if left blank).
# For Gmail: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=<App Password>.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your-smtp-username>
EMAIL_PASS=<your-smtp-password-or-app-password>
EMAIL_FROM=Shazli Traders <your@email.com>
ADMIN_EMAIL=<where-to-receive-new-order-alerts>

